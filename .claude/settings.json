{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.py)|Write(*.py)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-ruff.sh"
          },
          {
            "type": "command",
            "if": "Edit(*.tsx)|Write(*.tsx)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-prettier.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-pytest.sh",
            "statusMessage": "pytest 실행 중..."
          }
        ]
      }
    ]
  }
}
