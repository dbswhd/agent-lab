{
  "mcpServers": {
    "agent-lab-research": {
      "command": "$HOME/Projects/agent-lab/.venv/bin/python",
      "args": ["-m", "agent_lab.research.mcp_server"],
      "env": {
        "QUANT_PIPELINE_ROOT": "$HOME/Desktop/pipeline",
        "AGENTIC_TRADING_DB": "$HOME/Projects/quant-agentic-trading/data/agentic_trading/control_plane.sqlite3",
        "AGENT_LAB_SESSION_FOLDER": "$HOME/Projects/agent-lab/sessions/REPLACE_WITH_PREMARKET_SESSION",
        "AGENT_LAB_FRESHNESS_PYTHON": "$HOME/Desktop/pipeline/.venv/bin/python"
      }
    },
    "quant-trading": {
      "command": "$HOME/Projects/agent-lab/.venv/bin/python",
      "args": ["-m", "quant_pipeline.agentic_trading.mcp_server"],
      "env": {
        "PYTHONPATH": "$HOME/Projects/quant-agentic-trading/src",
        "QUANT_PIPELINE_ROOT": "$HOME/Desktop/pipeline",
        "AGENTIC_TRADING_DB": "$HOME/Projects/quant-agentic-trading/data/agentic_trading/control_plane.sqlite3",
        "AGENT_LAB_FRESHNESS_PYTHON": "$HOME/Desktop/pipeline/.venv/bin/python"
      }
    }
  }
}
