# --- Packaged app / GUI: copy to ~/.agent-lab/.env (absolute paths; GUI PATH is minimal) ---
# Flag catalog: `make list-flags` or GET /api/health/flags (?category=feature|infra|test)
# AGENT_LAB_SESSIONS_DIR=/Users/you/Projects/agent-lab/sessions
# AGENT_LAB_ROOT=/Users/you/Projects/agent-lab
# CODEX_BIN=/Users/you/.nvm/versions/node/v24.13.1/bin/codex
# CLAUDE_BIN=/Users/you/.nvm/versions/node/v24.13.1/bin/claude
# CURSOR_SDK_BRIDGE_BIN=/path/to/.venv/.../cursor-sdk-bridge
# See docs/STABILITY.md for config precedence (~/.agent-lab/.env → config.toml → repo .env).

# At least one provider is required.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Classic graph only (Planner/Critic/Scribe) — optional if you use 3자 룸 only
# Room Claude uses `claude login` (subscription); CLI subprocess ignores this key.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 3자 룸 — Claude agent (Claude Code CLI, subscription auth — not API key)
# Run: claude login
# CLAUDE_BIN=/Users/you/.nvm/versions/node/v24.13.1/bin/claude
# CLAUDE_MODEL=opus
# CLAUDE_REASONING_EFFORT=high          # low | medium | high | xhigh | max
# CLAUDE_ROOM_MAX_TASK=6                # max Task launches per Room turn (prompt budget)
# CLAUDE_ROOM_MAX_TASK_OUTPUT=12        # max TaskOutput polls per Room turn
# CLAUDE_SCRIBE_MODEL=opus             # optional; scribe-only model override
# CLAUDE_SCRIBE_REASONING_EFFORT=high
# CLAUDE_HANDOFF=short                 # short | full | off — system prompt handoff size
# CLAUDE_BARE=0                        # 1 = --bare (NO OAuth — API key only; breaks claude login)
# CLAUDE_PERMISSION_MODE=acceptEdits   # used when CLAUDE_SKIP_PERMISSIONS=0
# CLAUDE_SKIP_PERMISSIONS=1            # bypassPermissions + --dangerously-skip-permissions (default; headless tools)
# CLAUDE_DISABLE_TOOLS=1               # --tools "" (optional; off by default)
# CLAUDE_MAX_BUDGET_USD=0.50           # optional per-call cap (--print only)
# ROOM_SCRIBE_AGENT=codex              # plan synthesis backend (default claude)
# AGENT_LAB_ADVERSARIAL_LIVE=1         # dry-run adversarial note via live Claude (default: mock)
#
# --- GJC workflow pipeline (staged CLARIFY → CONSENSUS → EXECUTE) ---
# AGENT_LAB_PIPELINE=1                 # MASTER gate, DEFAULT ON. Auto-routes the staged
#                                      # mission loop (CLARIFY/CONSENSUS/EXECUTE via mode_router).
#                                      # Set 0 to fall back to legacy discuss-only behavior (only escape hatch).
# Manual handles (composer slash): /pipeline (status), /clarify (≈deep-interview),
#   /plan (≈ralplan). /clarify and /plan nudge mission_loop.phase; auto-routing still applies otherwise.
# Auxiliary stages stay OPT-IN (not bundled default-on):
# AGENT_LAB_CLARIFIER=1                # short/first-turn clarifier SSE before agents
# AGENT_LAB_CLARIFIER_MIN_CHARS=48     # topic length threshold for clarifier
# AGENT_LAB_CLARITY_THRESHOLD=0.30     # CLARIFY pass threshold (overall ambiguity, lateral panel)
# AGENT_LAB_CLARITY_TOPOLOGY=1         # opt-in: per-component decomposition+scoring (+1 agent call); questions target the vaguest part
# AGENT_LAB_CODE_MEMORY_MCP=1          # §5 Phase 0 code-memory MCP pilot (local, read-only, manual; default off; Claude/Codex only, no Cursor)
# AGENT_LAB_CODE_MEMORY_MODE=index     # code-memory mode: mock | index (default mock when enabled)
# AGENT_LAB_STAGE_ROUTING=1            # stage-aware routing: convergence/execute phases→single, divergence/audit→panel; user turn-profile always overrides (default off)
# AGENT_LAB_ANTIDRIFT=1                 # anti-drift defenses on panel turns: re-inject confirmed facts+decision ledger, unanimity->red-team, fresh-eyes critic seat (default off)
# AGENT_LAB_CHECKPOINT=0               # disable run.json FSM snapshot per phase transition → checkpoints.jsonl (default ON; opt-out via =0)
# AGENT_LAB_REPO_MAP=1                 # symbol-graph repo-map: ast def/ref ranking (seeded from plan/turn hints) replaces the plain repo tree in agent context (default off)
# AGENT_LAB_REPO_MAP_TOKENS=1024       # token budget for the repo-map output; drop lowest-ranked symbols on overflow (default 1024)
# AGENT_LAB_COMPACT_TOOL_OUTPUT=1      # deterministically truncate over-length code-fence tool/shell output in pre-current-turn agent messages before char-trim (default off)
# AGENT_LAB_COMPACT_TOOL_CHARS=2000    # per-code-fence-block char cap for tool-output compaction; head+tail+[...truncated N chars...] (default 2000)
# AGENT_LAB_SYNTAX_GATE=0              # disable merge hard-block on changed *.py SyntaxError (default ON; lint non-blocking; opt-out via =0)
# AGENT_LAB_SANDBOX_POLICY=0          # disable sandbox policy resolve at verify seam (default ON; worktree runtime => output identical)
# AGENT_LAB_SANDBOX_RUNTIME=worktree  # sandbox runtime when SANDBOX_POLICY on: worktree|docker (docker => worktree fallback + records sandbox_intent; default worktree)
# AGENT_LAB_EVAL_HARNESS=0            # disable POST /api/eval/score SWE-bench scorer route (default ON; pure stateless compute)
# AGENT_LAB_EVENT_MEMORY=0            # disable POST /api/memory/eval namespace KV route (default ON; pure stateless compute)
# AGENT_LAB_EVENT_VALIDATE=1          # validate + drop invalid live-log events in Room turns (default OFF; behavior change)
# AGENT_LAB_GOAL_LOOP=1                # session goal Oracle check after Room turns
# AGENT_LAB_PLAN_WORKFLOW=1            # default on for plan-mode send; 0 = legacy discuss-only plan
# AGENT_LAB_PLAN_INBOX=1               # inbox MCP during plan CLARIFY (default: same as EXECUTE_INBOX)
# AGENT_LAB_ORACLE_LIVE=1              # live Claude oracle for execute verify (default: mock)
# AGENT_LAB_GOAL_ORACLE_LIVE=1         # live oracle for session goal only (ORACLE_LIVE=1 enables both)
# AGENT_LAB_GOAL_AUTO_CONTINUE=1       # opt into one extra discuss round after FAIL
# AGENT_LAB_MISSION_BUDGET_USD=2.00    # mission cumulative USD ceiling; over → circuit-breaker pause (empty=unlimited)
# AGENT_LAB_BUDGET_WARN_PCT=80         # warn threshold as % of MISSION_BUDGET_USD (default 80)
# AGENT_LAB_DIFF_SAFETY=1              # pre-merge diff secret/danger scanner (default on; gates merge on findings)
# AGENT_LAB_TRACE=1                    # OTel-lite span tracer → sessions/<id>/trace.jsonl (default on)
# AGENT_LAB_CRASH_RECOVERY=1           # boot-time reconcile of crashed in-flight merges, G3 (default on)
# AGENT_LAB_MISSION_DUAL_WRITE=0       # opt-in Mission journal bridge; keep legacy writer first
# AGENT_LAB_MISSION_DUAL_WRITE_SESSIONS= # optional comma-separated cohort session IDs; empty = all when bridge is on
# AGENT_LAB_MISSION_PLAN_WRITE_AUTHORITY=1  # Slice 1: Mission owns plan phase; balanced/thorough/autonomous profile default on (requires DUAL_WRITE)
# AGENT_LAB_MISSION_INBOX_WRITE_AUTHORITY=1  # Slice 2: Mission owns inbox execution gates; same profile defaults (requires DUAL_WRITE)
# AGENT_LAB_MISSION_EXECUTION_WRITE_AUTHORITY=1  # Slice 3: fail-closed Mission commit after execute/merge/reverify (requires DUAL_WRITE)
# AGENT_LAB_JUDGE_LIVE=1               # live LLM-as-judge quality eval in score_session (default off)
# AGENT_LAB_JUDGE_MODEL=opus           # override Claude model for the judge (default scribe model)

# 3자 룸 — agent payload trim (constraints + plan 미결 + recent turns)
# AGENT_LAB_RECENT_TURNS=8
# AGENT_LAB_MAX_THREAD_CHARS=96000
# AGENT_LAB_NUMBERED_CONTEXT=1          # L{n} line refs in agent [최근 N턴] (default on)
# AGENT_LAB_CONTEXT_WARN_PCT=75         # trim_level warn when payload >= this % of max chars
# AGENT_LAB_CONTEXT_CRITICAL_PCT=90     # trim_level critical
# AGENT_LAB_MAX_AGREED_ITEMS=12
# AGENT_LAB_MAX_OPEN_ITEMS=14
# AGENT_LAB_R15=1                      # R1 summary bridge before round 2+
# AGENT_LAB_MAX_CONSENSUS_ROUNDS=12    # 자유 토론 합의 라운드 상한
# AGENT_LAB_MAX_CONSENSUS_CALLS=30     # 자유 토론 LLM 호출 상한 (human 턴당)
# 효율 모드 (Composer 「효율」 또는 AGENT_LAB_EFFICIENCY=1)
# AGENT_LAB_EFFICIENCY=0               # 1 = 모든 룸 호출에 효율 모드 기본 적용
# AGENT_LAB_EFFICIENCY_RECENT_TURNS=4
# AGENT_LAB_EFFICIENCY_MAX_PIN_MSGS=8
# AGENT_LAB_EFFICIENCY_PIN_BUDGET_PCT=50
# AGENT_LAB_EFFICIENCY_MAX_AGREED=6
# AGENT_LAB_EFFICIENCY_MAX_OPEN=6
# AGENT_LAB_EFFICIENCY_CONSENSUS_ROUNDS=8
# AGENT_LAB_EFFICIENCY_CONSENSUS_CALLS=20
# AGENT_LAB_SCRIBE_RECENT_TURNS=12     # scribe numbered thread trim
# AGENT_LAB_SCRIBE_MAX_CHARS=120000
# AGENT_LAB_SCRIBE_FULL=0              # 1 = full chat.jsonl for scribe

# Hook · Communicate reform (Room Router + reply policy — docs/HOOK-COMMUNICATE-REFORM.md)
# AGENT_LAB_HOOKS_PATH=~/.agent-lab/hooks.toml
# AGENT_LAB_HOOK_TIMEOUT_S=30
# AGENT_LAB_NATIVE_HOOKS=1             # stage session agent-hooks into workspace cwd
# AGENT_LAB_ENVELOPE_STRICT=consensus_only   # off | consensus_only | always
# AGENT_LAB_LEGACY_ENDORSE=0           # default off; 1 = phrase fallback 「이의 없습니다」
# AGENT_LAB_GUIDANCE_TIER=standard     # minimal | standard | debug (envelope block size)
# AGENT_LAB_STRUCTURED_ENVELOPE=1      # adapter JSON prefix / Claude --output-format json
# AGENT_LAB_AUTO_PLAN_SCRIBE=1         # re-scribe plan.md after every turn

# External runner (slash → local subprocess; ~/.agent-lab/tools.yaml)
# AGENT_LAB_EXTERNAL_TOOLS=1           # opt-in; session allowlist in Settings → Plugins → External

# 3자 룸 — Cursor agent (optional)
# CURSOR_API_KEY=                      # repo .env OK; first API boot mirrors into ~/.agent-lab/credentials.toml
# AGENT_LAB_SKIP_AUTH_BOOTSTRAP=1      # disable Codex OAuth + Cursor key sync on API startup
# AGENT_LAB_CLAUDE_HEADLESS_PROBE=1    # preflight runs claude -p probe (default: claude auth status only)
# CURSOR_MODEL=default   # Cursor SDK auto-pick (not the string "auto")
# Bridge: SDK uses cursor_sdk/_vendor/bridge/bin/cursor-sdk-bridge (set for .app if needed)
# CURSOR_SDK_BRIDGE_BIN=/path/to/.venv/lib/python3.13/site-packages/cursor_sdk/_vendor/bridge/bin/cursor-sdk-bridge
# If you see "ConnectError: Connection refused", unset stale IDE bridge env:
# CURSOR_SDK_BRIDGE_URL=  CURSOR_SDK_BRIDGE_TOKEN=
# QUANT_PIPELINE_ROOT=~/Projects/quant-pipeline
# LECTURE_SCRIPT_ROOT=~/Desktop/강의 스크립트/공수 기말 범위/book
# Book sessions: discuss + execute bind to LECTURE_SCRIPT_ROOT when plan/topic
# references build.mjs, break-report.json, RECIPE.md, etc. Session meta stores
# layout_frozen, session_phase (layout|content), workspace_binding in run.json.
# Golden baselines: book/golden/ with v1/v2 naming (see session_guidance.py).
# pip install -e ".[cursor]"

# Backend: codex (ChatGPT Plus via CLI) | openai | anthropic (classic graph)
# CODEX_REASONING_EFFORT=high
# CODEX_ROOM_REASONING_EFFORT=high   # 3자 룸 토론 (default high)
# CODEX_ROOM_TIMEOUT_SEC=240        # optional wall-clock cap (unset = no limit)
# CODEX_ROOM_IDLE_TIMEOUT_SEC=600   # fail when no JSONL/stderr for N sec (room; 0=off)
# CODEX_ROOM_HEARTBEAT_SEC=60       # UI heartbeat while Codex is thinking
# CLAUDE_ROOM_TIMEOUT_SEC=600        # optional — unset = no limit (room turn)
# CLAUDE_TIMEOUT_SEC=300             # optional — unset = no limit (scribe / non-room)
# CODEX_TIMEOUT_SEC=600              # optional — unset = no limit (classic graph)
# CODEX_ROOM_MAX_COMMANDS=6         # 룸 턴 shell 횟수 상한 (default 6)
# AGENT_LAB_DEBATE_ROUNDS=4          # ♾️ R2..R5 debate loop (review↔expand) before endorse
# AGENT_LAB_EFFICIENCY_DEBATE_ROUNDS=2
# CODEX_ROOM_WORKSPACE_WRITE=0      # 1 이면 룸에서도 workspace-write (느림·타임아웃 위험)
# CODEX_MODEL=gpt-5.5
# Full path if .app cannot find codex (which codex in Terminal)
# Required for Agent Lab.app (GUI has no nvm on PATH). Find: which codex
# CODEX_BIN=/Users/you/.nvm/versions/node/v24.13.1/bin/codex
# AGENT_LAB_PROVIDER=codex
# AGENT_LAB_WISDOM_INDEX=1             # MB-10: force wisdom index on (mission on = auto)
# AGENT_LAB_WISDOM_CROSS_SESSION=1     # MB-10: include other recent sessions in search
# AGENT_LAB_CODEX_PROXY=1              # MB-11 dev: route Codex via openai-oauth localhost proxy
# AGENT_LAB_CODEX_PROXY_URL=http://127.0.0.1:10531/v1

# Mission OS Phase 1 — scheduler + gateway outbound
# AGENT_LAB_MISSION_SCHEDULER=1              # background cron tick in API startup / agent-lab serve --daemon
# AGENT_LAB_MISSION_SCHEDULER_INTERVAL_S=60
# AGENT_LAB_ACTIVITY_QUEUE_RECOVERY=1        # eager startup + throttled ActivityQueue crash recovery (default on)
# AGENT_LAB_ACTIVITY_RECOVERY_INTERVAL_S=300 # periodic recovery interval; clamped to 30..3600 seconds
# AGENT_LAB_GATEWAY_CONFIG=~/.agent-lab/gateway.toml
# AGENT_LAB_DAEMON_STATE=~/.agent-lab/daemon_state.json
# AGENT_LAB_ROUTES_CONFIG=~/.agent-lab/routes.toml
# AGENT_LAB_GATE_SCOPE=1                       # lane-aware discuss pause (default on)
# AGENT_LAB_SKILL_DRAFTS=1                     # verify PASS → skill draft inbox (default on)
# AGENT_LAB_DAEMON_STALE_S=180                 # hybrid relay daemon-online threshold (seconds)
# AGENT_LAB_SCHEDULER_HOOK_TOKEN=              # optional auth for POST /api/mission-scheduler/tick and /api/hooks/mission-wake
# AGENT_LAB_TUNNEL_WAKE_URL=                   # Tier E soak — public cloudflared/ngrok base URL
# AGENT_LAB_SOAK_API_BASE=http://127.0.0.1:8765
